<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements injected when helper adhoc-resigns Zalo.app after `zadark install`.

  WHY: After ZaDark patches app.asar, VNG's original code signature breaks.
  Helper resigns with adhoc identity. WITHOUT explicit entitlements, the
  resign STRIPS VNG's original entitlements — including library validation
  rules + JIT permissions — causing Electron to crash on launch with
  "Library not loaded ... different Team IDs".

  These are the minimum entitlements an Electron-based app needs:
   - allow-jit + allow-unsigned-executable-memory: V8 JIT compilation
   - disable-library-validation: nested Frameworks may have mismatched
     Team IDs after our deep adhoc resign; this disables enforcement
   - device.audio-input + device.camera: Zalo voice/video calls

  These mirror what Zalo's original VNG signature granted (verified via
  `codesign -d --entitlements - /Applications/Zalo.app` on a fresh install).
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <key>com.apple.security.device.camera</key>
    <true/>
</dict>
</plist>
